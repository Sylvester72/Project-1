<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSCalendarsUsageDescription</key>
    <string>AST AI needs calendar access to manage your events and meetings.</string>
    <key>NSRemindersUsageDescription</key>
    <string>AST AI uses reminders to set and manage tasks.</string>
    <key>NSContactsUsageDescription</key>
    <string>AST AI may access contacts to help identify callers and recipients.</string>
</dict>
</plist>
